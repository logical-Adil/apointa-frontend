# --- API (production) --------------------------------------------------------
# e.g. same host, path prefix: NEXT_PUBLIC_API_URL=https://itsadil.site/api
#
# --- Subpath hosting (Next.js basePath) --------------------------------------
# Build with: NEXT_PUBLIC_BASE_PATH=/appointa-client
# (must match nginx location; omit for root hosting)
#
# --- Same-origin proxy (local dev) ------------------------------------------
# Leave NEXT_PUBLIC_API_URL unset so the browser calls /v1/... on this app;
# Next.js rewrites those to the Express server (see client/next.config.ts).
# Optional: override where rewrites point (default http://localhost:5000).
# BACKEND_ORIGIN=http://localhost:5000
#
# Alternative: call the API directly (cross-origin; session cookie must still
# reach the backend — use the same hostname as the app, e.g. only localhost).
# NEXT_PUBLIC_API_URL=http://localhost:5000
#
# Chat Socket.io: same-origin `https://<host>/socket.io` (Next rewrites in dev;
# nginx `location /socket.io/` in prod). No NEXT_PUBLIC_SOCKET_* vars.